<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Black List Hub</title>
    <link rel="icon" type="image/png" href="/black.png">
    <link rel="stylesheet" href="/style.css">
    <!-- تأكد من تعديل رابط الفونت أوسوم إذا لزم الأمر -->
    <link rel="stylesheet" href="https://cloudflare.com">
</head>

<body>

    <!-- 1. شاشة الترحيب (توضع هنا لتظهر فوق كل شيء فوراً) -->
    <div id="welcome-overlay" class="welcome-overlay">
        <div class="intro-card">
            <div class="card-border-animation"></div>
            <div class="intro-content">
                <img src="/black.png" alt="Black List Logo" class="intro-logo">
                <p class="intro-text">
                    لسنا مجرد مجموعة أشخاص داخل لعبة أو سيرفر… نحن كيانٌ يحمل هويةً خاصة، وهيبةً لا يستطيع أي شخص تقليدها أو الوصول إليها بسهولة.
                </p>
            </div>
        </div>
    </div>

    <div class="animated-bg"></div>

    <header class="main-header">
        <img src="/black.png" alt="Logo" class="header-logo">
        <div class="header-btns">
            <button class="plus-btn" onclick="openSocial()">حساباتنا</button>
            <button class="plus-btn" onclick="openAddModal()">+ أضف قناتك</button>
        </div>
    </header>

    <!-- الإحصائيات -->
    <div class="stats-container">
        <div class="stat-item"><small>الستريمرز</small>
            <h3><%= stats.totalStreamers %></h3>
        </div>
        <div class="stat-item"><small>مشاهدة</small>
            <h3 style="color: var(--neon-blue);"><%= stats.totalViewers %></h3>
        </div>
        <div class="stat-item"><small>نشط</small>
            <h3 style="color: #53fc18;"><%= stats.liveNow %></h3>
        </div>
    </div>

    <!-- الفلترة -->
    <div class="filter-container">
        <select class="filter-select" onchange="runFilter(this.value)">
            <option value="all">جميع القنوات</option>
            <option value="live">البث المباشر</option>
            <option value="offline">غير متصل</option>
            <option value="fav">المفضلة</option>
            <option value="high">الأعلى مشاهدة</option>
        </select>
    </div>

    <div class="cards-grid" id="mainGrid">
        <% streamers.forEach(streamer => { %>
            <div class="card" id="card-<%= streamer.kickUsername %>" data-viewers="<%= streamer.viewers %>" data-live="<%= streamer.isLive %>">
                <i class="fas fa-star star-btn" onclick="toggleFav('<%= streamer.kickUsername %>')"></i>
                <div class="profile-side">
                    <img src="<%= streamer.profilePic || '/black.png' %>" class="profile-img">
                    <div class="viewers-count">VIEWERS <%= streamer.viewers %></div>
                </div>
                <div class="card-content">
                    <div class="kick-tag">KICK</div>
                    <h3><%= streamer.kickUsername %></h3>
                    <% if(streamer.isLive) { %>
                        <div class="live-badge">LIVE</div><br>
                        <a href="https://kick.com/<%= streamer.kickUsername %>" target="_blank" class="watch-btn">مشاهدة البث</a>
                    <% } else { %>
                        <div style="color: #555; font-size: 11px;">غير متصل</div><br>
                        <a href="https://kick.com/<%= streamer.kickUsername %>" target="_blank" class="watch-btn offline">زيارة القناة</a>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- المودالات -->
    <div id="socialModal" class="modal-overlay">
        <div class="modal-box">
            <h3 style="margin-bottom:20px;">حسابات عصابة بلاك ليست</h3>
            <div style="display: grid; gap: 10px;">
                <a href="https://x.com" target="_blank" class="plus-btn" style="text-decoration:none; background:#1da1f2;">تويتر X</a>
                <a href="https://discord.gg" target="_blank" class="plus-btn" style="text-decoration:none; background:#5865f2;">ديسكورد</a>
            </div>
            <button onclick="closeSocial()" style="margin-top:20px; background:none; color:gray; border:none; cursor:pointer;">إغلاق</button>
        </div>
    </div>

    <div id="addModal" class="modal-overlay">
        <div class="modal-box">
            <h3 style="color: var(--neon-blue);">انضم للمنصة</h3>
            <form action="/apply" method="POST">
                <input type="text" name="kickUser" placeholder="اسمك في Kick" required style="width:100%; padding:10px; margin:10px 0; background:#222; border:none; color:white; border-radius:8px;">
                <button type="submit" class="plus-btn" style="width:100%; background:var(--neon-blue); color:black;">إرسال الطلب</button>
                <button type="button" onclick="closeAddModal()" style="margin-top:15px; background:none; color:gray; border:none; cursor:pointer;">إلغاء</button>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // 1. سكربت إغلاق شاشة الترحيب
        setTimeout(() => {
            const overlay = document.getElementById('welcome-overlay');
            if(overlay) {
                overlay.style.opacity = '0';
                setTimeout(() => { overlay.style.display = 'none'; }, 1000);
            }
        }, 7000);

        // 2. وظائف المودالات والمفضلة
        function openSocial() { document.getElementById('socialModal').style.display = 'flex'; }
        function closeSocial() { document.getElementById('socialModal').style.display = 'none'; }
        function openAddModal() { document.getElementById('addModal').style.display = 'flex'; }
        function closeAddModal() { document.getElementById('addModal').style.display = 'none'; }

        function toggleFav(user) {
            let favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            const index = favs.indexOf(user);
            index > -1 ? favs.splice(index, 1) : favs.push(user);
            localStorage.setItem('bl_favs', JSON.stringify(favs));
            updateStars();
        }

        function updateStars() {
            let favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            document.querySelectorAll('.card').forEach(c => {
                const user = c.id.replace('card-', '');
                c.querySelector('.star-btn').classList.toggle('active', favs.includes(user));
            });
        }

        function runFilter(val) {
            const cards = Array.from(document.querySelectorAll('.card'));
            const favs = JSON.parse(localStorage.getItem('bl_favs')) || [];
            const grid = document.getElementById('mainGrid');
            cards.forEach(c => {
                c.style.display = 'flex';
                const user = c.id.replace('card-', '');
                if (val === 'live' && c.dataset.live === 'false') c.style.display = 'none';
                if (val === 'offline' && c.dataset.live === 'true') c.style.display = 'none';
                if (val === 'fav' && !favs.includes(user)) c.style.display = 'none';
            });
            if (val === 'high') {
                cards.sort((a, b) => b.dataset.viewers - a.dataset.viewers);
                grid.innerHTML = ""; cards.forEach(c => grid.appendChild(c));
            }
        }
        window.onload = updateStars;
    </script>
</body>
</html>
