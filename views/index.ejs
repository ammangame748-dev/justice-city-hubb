<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta name="referrer" content="no-referrer">
   <link rel="icon" type="image/png" href="/logo.png?v=2">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Justice City | Hub الملكي</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        .bg-logo {
    position: fixed;
    top: 50%;
    left: 50%;
    width: 750px;
    height: 750px;
    background: url('/logo.png') no-repeat center;
    background-size: contain;
    opacity: 0.04;
    transform: translate(-50%, -50%);
    z-index: -2;
    pointer-events: none;
    filter: blur(1.5px) drop-shadow(0 0 80px rgba(212,175,55,0.25));
    animation: floatLogo 14s ease-in-out infinite;
}

@keyframes floatLogo {
    0% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    50% { transform: translate(-50%, -48%) scale(1.08) rotate(3deg); }
    100% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
}
body::before {
    content: "";
    position: fixed;
    top: 50%;
    left: 50%;
    width: 800px;
    height: 800px;
    background: url('/logo.png') no-repeat center;
    background-size: contain;
    opacity: 0.05;
    transform: translate(-50%, -50%);
    z-index: -1;
    pointer-events: none;
    filter: blur(1px) drop-shadow(0 0 80px rgba(212,175,55,0.3));
    animation: floatLogo 12s ease-in-out infinite;
}

@keyframes floatLogo {
    0% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    50% { transform: translate(-50%, -48%) scale(1.05) rotate(3deg); }
    100% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
}
        /* تنسيق جعل النافذة تظهر في منتصف الشاشة تماماً */
#apply-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8); /* خلفية سوداء شفافة */
    display: none; /* مخفي افتراضياً */
    justify-content: center;
    align-items: center;
    z-index: 2000; /* أعلى من كل شيء */
    backdrop-filter: blur(5px);
}

        .btn-support {
    background: rgba(212, 175, 55, 0.1);
    color: #d4af37 !important;
    border: 1px dashed #d4af37;
    text-decoration: none;
    margin-left: 20px;
    font-weight: bold;
    padding: 8px 20px;
    border-radius: 8px;
    transition: 0.3s;
}

.btn-support:hover {
    background: #d4af37;
    color: black !important;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
    border-style: solid;
}

       /* الحاوية الرئيسية للإحصائيات عشان تصفهم جنب بعض */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); /* هاد السطر بجبرهم يصفوا 3 جنب بعض */
    gap: 20px;
    margin: 40px auto;
    width: 100%;
    max-width: 1200px;
    padding: 0 20px;
    box-sizing: border-box;
}

.stat-box {
    background: rgba(15, 15, 15, 0.9);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    transition: 0.3s;
}

.stat-box:hover {
    border-color: #d4af37;
    transform: translateY(-5px);
}

.stat-number {
    font-size: 32px;
    font-weight: bold;
    color: #fff;
    display: block;
    margin-bottom: 5px;
}

.stat-desc {
    color: #888;
    font-size: 14px;
    font-weight: bold;
}

/* للموبايل عشان ما يخرب الشكل */
@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: 1fr;
    }
}


/* حركة نبض للستريمر النشط */
.live-pulse {
    border-color: rgba(0, 255, 153, 0.2);
}
.live-pulse:hover {
    border-color: #00ff99;
}

        :root {
            --bg: #050505;
            --gold: linear-gradient(45deg, #d4af37, #f9f295, #d4af37);
            --card-bg: rgba(20, 20, 20, 0.8);
            --neon-gold: 0 0 15px rgba(212, 175, 55, 0.5);
        }

        body { margin: 0; font-family: 'Changa', sans-serif; background: var(--bg); color: white; overflow-x: hidden; }
      #tsparticles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background-color: #050505;
}

/* ================= NAVBAR ================= */
nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 40px;

    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(15px);

    position: sticky;
    top: 0;
    z-index: 1000;

    border-bottom: 1px solid rgba(212, 175, 55, 0.25);

    box-shadow: 0 0 25px rgba(0,0,0,0.6);
}

/* ================= NAV LINKS ================= */
.nav-links a {
    position: relative;
    overflow: hidden;

    color: #d4af37;
    text-decoration: none;
    margin-left: 12px;
    font-weight: bold;

    padding: 10px 18px;
    border-radius: 12px;

    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(212,175,55,0.25);

    transition: 0.3s;
}

.nav-links a:hover {
    background: #d4af37;
    color: #000;
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(212,175,55,0.5);
}

/* لمعة ذهبية */
.nav-links a::before {
    content: "";
    position: absolute;
    top: 0;
    left: -120%;
    width: 100%;
    height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.25), transparent);
    transition: 0.5s;
}

.nav-links a:hover::before {
    left: 120%;
}

/* ================= CONTAINER ================= */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}

/* ================= PODIUM ================= */
.podium {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 20px;

    margin: 60px 0 100px 0;
    padding-bottom: 20px;
}

/* ================= PODIUM CARD ================= */
.podium-card {
    background: rgba(10, 10, 10, 0.85);
    border-radius: 20px;

    width: 250px;
    text-align: center;

    padding: 30px 15px;
    position: relative;

    border: 1px solid rgba(212,175,55,0.2);

    transition: 0.4s;
}

/* مراكز */
.podium-card.first {
    height: 350px;
    border: 2px solid #f9f295;
    box-shadow: 0 0 25px rgba(212,175,55,0.4);
    z-index: 2;
}

.podium-card.second {
    height: 280px;
    border: 2px solid #d7dde8;
}

.podium-card.third {
    height: 230px;
    border: 2px solid #f0be99;
}

/* hover */
.podium-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 0 20px rgba(212,175,55,0.25);
}

/* ================= MEDAL ================= */
.medal {
    font-size: 50px;
    margin-bottom: 10px;
    display: block;
}

        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
            gap: 20px; 
            margin-top: 50px; 
        }
.card {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);

    border-radius: 18px;
    padding: 25px 15px;
    text-align: center;
    position: relative;
    transition: 0.4s;

    /* إطار ذهبي أسود متحرك */
    border: 2px solid transparent;
    background-image: linear-gradient(#0a0a0a, #0a0a0a),
                      linear-gradient(120deg, #000, #d4af37, #000);
    background-origin: border-box;
    background-clip: padding-box, border-box;

    animation: borderMove 5s linear infinite;
}

@keyframes borderMove {
    0% { background-position: 0 0; }
    100% { background-position: 300% 0; }
}

.card:hover {
    transform: translateY(-10px) scale(1.03);
    box-shadow: 0 0 25px rgba(212,175,55,0.4);
}
/* تنسيق أزرار الفلترة بألوان الموقع الذهبية */
.filter-container {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin: 30px 0;
}
.filter-btn {
    background: rgba(20, 20, 20, 0.8);
    color: #d4af37;
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 10px 30px;
    border-radius: 10px;
    cursor: pointer;
    font-family: 'Changa';
    font-weight: bold;
    transition: 0.3s;
}
.filter-btn.active, .filter-btn:hover {
    background: var(--gold); /* اللون الذهبي تبع موقعك */
    color: black;
    box-shadow: var(--neon-gold);
    border-color: transparent;
}
.fav-star {
    font-size: 22px;
    color: #777;
    transition: 0.3s;
    user-select: none;
}

.fav-star.active {
    color: #d4af37;
    text-shadow: 0 0 10px #d4af37;
}

    </style>
    <!-- حط هاد السطر قبل </head> -->
<script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>

</head>
<body>
<div class="bg-logo"></div>
    <div id="tsparticles"></div>


<nav>
    <div style="display: flex; align-items: center; gap: 15px;">
        <!-- هون بنادي الصورة اللي حطيتها بمجلد public -->
        <img src="/logo.png" style="width: 55px; height: 55px; border-radius: 10px; object-fit: cover; filter: drop-shadow(0 0 5px #d4af37);">

        
        <span style="background: var(--gold); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 24px; font-weight: bold; font-family: 'Changa';">
            JUSTICE CITY HUB
        </span>
    </div>
    
    <div class="nav-links">
        <a href="javascript:void(0)" onclick="showFavorites()">⭐ المفضلة</a>
            <a href="https://paypal.me/HosamHamaideh" target="_blank" class="btn-support">☕ ادعم المشروع</a>
        <a href="javascript:void(0)" onclick="toggleRankings()">🏆 المتصدرين</a>
        <a href="javascript:void(0)" onclick="openModal()" class="btn-apply">🔗 أضف قناتك</a>
    </div>
</nav>

<div class="filter-container">
    <button onclick="filterStreamers('all', event)" class="filter-btn active">الكل</button>
    <button onclick="filterStreamers('live', event)" class="filter-btn">البث المباشر</button>
    <button onclick="filterStreamers('offline', event)" class="filter-btn">غير متصل</button>
</div>


    <div class="container">
        <!-- تعديل هذا السطر ليصبح مخفياً في البداية -->
<div id="rankings" class="animate" style="text-align: center; margin-top: 40px; display: none;">

            <h1 style="background: var(--gold); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 50px;">نخبة الستريمرز</h1>
            <div class="podium">
                <div class="podium-card second">
                    <span class="medal">🥈</span>
                    <h3 style="color: #d7dde8;">المركز الثاني</h3>
                    <p style="color: #666;">قريباً..</p>
                </div>
                <div class="podium-card first">
                    <span class="medal">🥇</span>
                    <h2 style="color: #f9f295; font-size: 30px;">المركز الأول</h2>
                    <p style="color: #888;">ملك البثوث</p>
                </div>
                <div class="podium-card third">
                    <span class="medal">🥉</span>
                    <h3 style="color: #f0be99;">المركز الثالث</h3>
                    <p style="color: #666;">في طريق القمة</p>
                </div>
            </div>
        </div>

</div>
<div class="stats-grid">
    <!-- كرت 1 -->
    <div class="stat-box">
        <div class="stat-content">
            <span class="stat-number"><%= stats.totalStreamers %></span>
            <span class="stat-desc">إجمالي الستريمرز</span>
        </div>
    </div>

    <!-- كرت 2 -->
    <div class="stat-box">
        <div class="stat-content">
            <span class="stat-number"><%= stats.totalViewers %></span>
            <span class="stat-desc">مشاهد حالياً</span>
        </div>
    </div>

    <!-- كرت 3 -->
    <div class="stat-box">
        <div class="stat-content">
            <span class="stat-number" style="color: #00ff99;"><%= stats.liveNow %></span>
            <span class="stat-desc">ستريمر نشط الآن</span>
        </div>
    </div>
</div> <!-- القفلة هاي هي اللي كانت ناقصة عندك ومخربة الدنيا -->




 <div class="grid">
    <% if (streamers && streamers.length > 0) { %>
        <% streamers.forEach(function(s) { %>
            <!-- استخدمنا s بدل streamer لأنك عرفتها في الـ function(s) -->
            <div class="card <%= s.isLive ? 'live' : '' %>" data-status="<%= s.isLive ? 'live' : 'offline' %>">
                <div style="position:absolute; top:10px; left:10px; cursor:pointer;">
    <span class="fav-star" data-user="<%= s.kickUsername %>" onclick="toggleFavorite('<%= s.kickUsername %>')">
        ☆
    </span>
</div>
                <!-- تصليح رابط الصورة وصورة احتياطية في حال الفشل -->
                <img src="<%= s.profilePic || '/logo.png' %>" 
     class="avatar" 
     alt="avatar" 
     onerror="this.src='/logo.png'">


                <h3 style="margin: 10px 0;"><%= s.kickUsername %></h3>

                <% if (s.isLive) { %>
                    <div style="color: #00ff99; font-weight: bold; margin-bottom: 10px;">
                         🔴 مباشر الآن
                         <br>
                         <span style="font-size: 14px; color: #d4af37;">👀 <%= s.viewers %> مشاهد</span>
                    </div>
                <% } else { %>
                    <div style="color: #666; margin-bottom: 10px;">غير متصل</div>
                <% } %>

                <!-- تصليح رابط القناة (إضافة السلاش /) -->
                <a href="https://kick.com/<%= s.kickUsername %>" target="_blank" class="btn">
                    <%= s.isLive ? 'دخول البث' : 'دخول القناة' %>
                </a>
            </div>
        <% }); %>
    <% } else { %>
        <div style="text-align:center; color:#777; font-size:20px; grid-column: 1 / -1;">🚫 لا يوجد ستريمرز حالياً</div>
    <% } %>
</div>

        </div>
    </div>
    <!-- نافذة أضف قناتك -->
    <div id="apply-modal" style="display: none;">
        <div class="card" style="width: 380px; border: 2px solid #d4af37; padding: 30px; position: relative;">
            <h2 style="color: #d4af37; margin-bottom: 20px;">🔗 أضف قناتك</h2>
            <form action="/apply" method="POST">
                <input type="text" name="kickUser" placeholder="اسم قناتك في Kick" required 
                       style="display: block; width: 100%; box-sizing: border-box; padding: 15px; margin-bottom: 15px; background: #000; color: #fff; border: 1px solid rgba(212, 175, 55, 0.4); border-radius: 10px; font-family: 'Changa'; text-align: center;">
                
                <button type="submit" class="btn" style="width: 100%; cursor: pointer; border: none;">إرسال الطلب</button>
                
                <button type="button" onclick="closeModal()" 
                        style="background: none; color: #777; border: none; margin-top: 15px; cursor: pointer; font-family: 'Changa'; font-size: 14px;">
                    إغلاق النافذة
                </button>
            </form>
        </div>
    </div>

    <!-- السكريبت الموحد لكل الوظائف -->
    <script>
function filterStreamers(type, event) {
    // 1. تحديث شكل الأزرار (إزالة active من الكل وإضافتها للزر المضغطوط)
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    if (event) {
        event.currentTarget.classList.add('active');
    }

    // 2. جلب كل الكروت الموجودة داخل الـ grid
    const cards = document.querySelectorAll('.grid .card');
    
    cards.forEach(card => {
        // فحص هل الكرت يحتوي على كلاس live (اللي أنت ضايفه أصلاً في EJS)
        const isLive = card.classList.contains('live');

        if (type === 'all') {
            card.style.display = 'block'; // إظهار الكل
        } else if (type === 'live') {
            card.style.display = isLive ? 'block' : 'none'; // إظهار اللايف فقط
        } else if (type === 'offline') {
            card.style.display = !isLive ? 'block' : 'none'; // إظهار الأوفلاين فقط
        }
    });

    console.log("Filtering done for:", type); // للتأكد في Console المتصفح
}


        // وظائف النافذة المنبثقة (Modal)
        function openModal() { 
            document.getElementById('apply-modal').style.display = 'flex'; 
        }
        
        function closeModal() { 
            document.getElementById('apply-modal').style.display = 'none'; 
        }

        // وظيفة إظهار وإخفاء المتصدرين (Rankings)
        function toggleRankings() {
            const rankings = document.getElementById('rankings');
            // التأكد من حالة العرض الحالية
            if (rankings.style.display === 'none' || rankings.style.display === '') {
                rankings.style.display = 'block';
                // نزول تلقائي للقسم عند فتحه
                rankings.scrollIntoView({ behavior: 'smooth' });
            } else {
                rankings.style.display = 'none';
            }
        }

        // إغلاق النافذة عند الضغط خارجها (اختياري لزيادة الاحترافية)
        window.onclick = function(event) {
            const modal = document.getElementById('apply-modal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
    <script>
async function loadParticles() {
    await tsParticles.load("tsparticles", {
        particles: {
            number: { value: 80 },
            color: { value: ["#ff7b00", "#d4af37"] },
            shape: { type: "circle" },
            opacity: { value: 0.4 },
            size: { value: { min: 1, max: 3 } },
          move: {
    enable: true,
    speed: 1.5,
    direction: "top",
    random: true,
    outModes: { default: "out" }
}
        },
        background: {
            color: "#050505"
        }
    });
}

loadParticles();
loadParticles();
</script>
<script>
  // كود بخلي الصفحة تعمل ريفريش لحالها كل دقيقة عشان تحديث الحالات
  setTimeout(function(){
     location.reload();
  }, 60000); 
  function getFavorites() {
    return JSON.parse(localStorage.getItem('favorites') || '[]');
}

function saveFavorites(favs) {
    localStorage.setItem('favorites', JSON.stringify(favs));
}

function toggleFavorite(username) {
    let favs = getFavorites();

    if (favs.includes(username)) {
        favs = favs.filter(u => u !== username);
        alert("تم إزالة الستريمر من المفضلة");
    } else {
        favs.push(username);
        alert("⭐ تم إضافة الستريمر للمفضلة");
    }

    saveFavorites(favs);
    updateStars();
}

function updateStars() {
    const favs = getFavorites();

    document.querySelectorAll('.fav-star').forEach(star => {
        const user = star.getAttribute('data-user');

        if (favs.includes(user)) {
            star.classList.add('active');
            star.textContent = '★';
        } else {
            star.classList.remove('active');
            star.textContent = '☆';
        }
    });
}

function showFavorites() {
    const favs = getFavorites();
    const cards = document.querySelectorAll('.grid .card');

    cards.forEach(card => {
        const username = card.querySelector('h3').innerText;

        if (favs.includes(username)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

// تشغيل النجوم عند تحميل الصفحة
updateStars();
</script>

</body>
</html> 
