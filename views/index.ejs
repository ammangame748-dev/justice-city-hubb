<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Justice City Hub</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <script src="https://jsdelivr.net"></script>

    <style>
        :root {
            --bg: #0b0c10;
            --card-bg: rgba(255, 255, 255, 0.03);
            --border: rgba(212, 175, 55, 0.2); /* ذهبي خفيف لابق للوجو */
            --gold: #d4af37;
            --live: #00ff99;
            --text: #e0e0e0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Changa', sans-serif; }
        body { background: var(--bg); color: var(--text); overflow-x: hidden; }

        /* اللوجو العائم في الخلفية - خفيف جداً وراقي */
        .watermark {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 500px; opacity: 0.04; z-index: -1; pointer-events: none;
        }

        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 10px 40px; background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px); border-bottom: 1px solid var(--border);
            position: sticky; top: 0; z-index: 100;
        }
        .brand { display: flex; align-items: center; gap: 12px; }
        .brand img { width: 42px; height: 42px; border-radius: 8px; }
        .brand h1 { font-size: 20px; letter-spacing: 1px; color: var(--gold); }

        .stats-bar {
            display: flex; justify-content: center; gap: 30px; 
            padding: 20px; background: rgba(255,255,255,0.02); margin-bottom: 20px;
        }
        .stat-item { text-align: center; }
        .stat-item span { display: block; font-size: 12px; color: #888; }
        .stat-item b { font-size: 18px; color: var(--gold); }

        .filters { display: flex; justify-content: center; gap: 10px; margin: 20px 0; }
        .filters button { 
            background: none; border: 1px solid var(--border); color: #888;
            padding: 6px 18px; border-radius: 20px; cursor: pointer; transition: 0.3s;
        }
        .filters button.active { background: var(--gold); color: #000; border-color: var(--gold); }

        .grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px; max-width: 1100px; margin: 0 auto; padding: 20px;
        }

        /* تصميم الكرت الصغير والأنيق */
        .card {
            background: var(--card-bg); border: 1px solid var(--border);
            border-radius: 16px; padding: 20px; text-align: center;
            transition: 0.3s ease; position: relative; overflow: hidden;
        }
        .card:hover { transform: translateY(-5px); border-color: var(--gold); background: rgba(255,255,255,0.06); }
        
        .card.live { border-color: var(--live); }
        .live-dot { 
            position: absolute; top: 12px; right: 12px; width: 8px; height: 8px;
            background: var(--live); border-radius: 50%; box-shadow: 0 0 10px var(--live);
        }

        /* صورة الستريمر الحقيقية */
        .avatar {
            width: 75px; height: 75px; border-radius: 50%;
            object-fit: cover; border: 2px solid var(--border);
            margin-bottom: 12px; background: #1a1a1a;
        }
        .card.live .avatar { border-color: var(--live); }

        .username { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
        .view-count { font-size: 13px; color: #888; display: flex; align-items: center; justify-content: center; gap: 5px; }
        
        .btn-kick {
            display: inline-block; margin-top: 15px; padding: 7px 20px;
            border-radius: 10px; background: var(--gold); color: #000;
            text-decoration: none; font-weight: 700; font-size: 13px; width: 100%;
        }

        .modal { 
            position: fixed; inset: 0; background: rgba(0,0,0,0.8); 
            display: none; justify-content: center; align-items: center; z-index: 1000;
        }
        .modal-content { background: #15161a; padding: 30px; border-radius: 20px; border: 1px solid var(--gold); width: 320px; }
        input { width: 100%; padding: 12px; background: #000; border: 1px solid #333; color: #fff; border-radius: 10px; margin: 15px 0; }
    </style>
</head>
<body>
<img src="/logo.png" class="watermark" />
<div id="tsparticles"></div>

<nav>
    <div class="brand">
        <img src="/logo.png" />
        <h1>JUSTICE HUB</h1>
    </div>
    <button onclick="openModal()" style="background:var(--gold); border:none; padding:8px 15px; border-radius:10px; cursor:pointer; font-weight:bold;">+ إضافة</button>
</nav>

<div class="stats-bar">
    <div class="stat-item"><span>الستريمرز</span><b><%= stats.totalStreamers %></b></div>
    <div class="stat-item"><span>المشاهدات</span><b><%= stats.totalViewers %></b></div>
    <div class="stat-item"><span>لايف</span><b style="color:var(--live)"><%= stats.liveNow %></b></div>
</div>

<div class="filters">
    <button class="active" onclick="filter('all')">الكل</button>
    <button onclick="filter('live')">بث مباشر</button>
</div>

<div class="grid">
<% streamers.forEach(s => { %>
    <div class="card <%= s.isLive ? 'live' : '' %>" data-status="<%= s.isLive ? 'live' : 'offline' %>">
        <% if(s.isLive){ %><div class="live-dot"></div><% } %>
        
        <!-- استخدام صورة الستريمر الحقيقية المسحوبة من السيرفر -->
        <img class="avatar" src="<%= s.profilePic || '/logo.png' %>" alt="<%= s.kickUsername %>">
        
        <div class="username"><%= s.kickUsername %></div>
        
        <div class="view-count">
            <% if(s.isLive) { %>
                <span style="color:var(--live)">●</span> <%= s.viewers.toLocaleString() %> مشاهد
            <% } else { %>
                <span style="color:#555">OFFLINE</span>
            <% } %>
        </div>

        <a class="btn-kick" href="https://kick.com/<%= s.kickUsername %>" target="_blank">مشاهدة</a>
    </div>
<% }) %>
</div>

<div class="modal" id="modal" onclick="if(event.target==this) closeModal()">
    <div class="modal-content">
        <h3 style="text-align:center">تقديم طلب انضمام</h3>
        <form action="/apply" method="POST">
            <input name="kickUser" placeholder="اسم المستخدم في Kick" required />
            <button type="submit" class="btn-kick" style="border:none; cursor:pointer">إرسال الطلب</button>
        </form>
    </div>
</div>

<script>
    function openModal(){ document.getElementById('modal').style.display='flex'; }
    function closeModal(){ document.getElementById('modal').style.display='none'; }

    function filter(t){
        document.querySelectorAll('.filters button').forEach(b => b.classList.remove('active'));
        event.target.classList.add('active');
        document.querySelectorAll('.card').forEach(c => {
            if(t==='all') c.style.display='block';
            else if(t==='live') c.style.display = c.classList.contains('live') ? 'block' : 'none';
        });
    }

    // جزيئات ذهبية ناعمة جداً تناسب اللوجو
    tsParticles.load("tsparticles", {
        particles: {
            number: { value: 40 },
            color: { value: "#d4af37" },
            move: { enable: true, speed: 0.5 },
            size: { value: 1 },
            opacity: { value: 0.3 }
        }
    });
</script>
</body>
</html>
