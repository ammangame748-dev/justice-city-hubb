    border-radius: 20px;
    font-size: 13px;
    border: 1px solid rgba(212, 175, 55, 0.2);
    display: flex;
    align-items: center;
    gap: 5px;
}

/* زر دخول القناة */
.btn-visit {
    background: linear-gradient(45deg, #d4af37, #f9f295);
