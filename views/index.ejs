<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Justice City Hub | Reborn</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Changa:wght@300;400;600;800&display=swap" rel="stylesheet">

    <!-- Particles -->
    <script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>

    <style>
        :root{
            --bg:#050608;
            --panel:#0e0f14;
            --panel2:#12141c;
            --gold:#d4af37;
            --gold2:#f9f295;
            --text:#ffffff;
            --muted:#8a8f98;
            --green:#00ff99;
            --red:#ff3b3b;
            --border:rgba(212,175,55,0.25);
            --shadow:0 0 25px rgba(212,175,55,0.25);
        }

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Changa',sans-serif;
        }

        body{
            background:var(--bg);
            color:var(--text);
            overflow-x:hidden;
        }

        /* particles */
        #tsparticles{
            position:fixed;
            inset:0;
            z-index:-1;
        }

        /* top nav */
        nav{
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:15px 40px;
            background:rgba(10,10,10,0.7);
            backdrop-filter:blur(12px);
            border-bottom:1px solid var(--border);
            position:sticky;
            top:0;
            z-index:999;
        }

        .brand{
            display:flex;
            align-items:center;
            gap:12px;
        }

        .brand img{
            width:45px;
            height:45px;
            border-radius:10px;
            box-shadow:var(--shadow);
        }

        .brand h1{
            font-size:18px;
            background:linear-gradient(45deg,var(--gold),var(--gold2));
            -webkit-background-clip:text;
            -webkit-text-fill-color:transparent;
        }

        .nav-links a{
            margin-right:12px;
            text-decoration:none;
            color:var(--text);
            padding:8px 14px;
            border-radius:10px;
            font-weight:600;
            transition:.3s;
        }

        .nav-links a:hover{
            background:rgba(212,175,55,0.15);
        }

        .btn-gold{
            border:1px solid var(--gold);
            color:var(--gold)!important;
        }

        /* hero stats */
        .stats{
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:20px;
            max-width:1100px;
            margin:40px auto;
            padding:0 20px;
        }

        .stat{
            background:linear-gradient(145deg,var(--panel),var(--panel2));
            padding:25px;
            border-radius:16px;
            border:1px solid var(--border);
            text-align:center;
            transition:.3s;
        }

        .stat:hover{
            transform:translateY(-5px);
            box-shadow:var(--shadow);
        }

        .stat h2{
            font-size:28px;
            color:var(--gold2);
        }

        .stat p{
            color:var(--muted);
            margin-top:5px;
        }

        /* filters */
        .filters{
            display:flex;
            justify-content:center;
            gap:10px;
            margin:20px 0;
        }

        .filters button{
            padding:10px 18px;
            border-radius:10px;
            border:1px solid var(--border);
            background:var(--panel);
            color:var(--text);
            cursor:pointer;
            transition:.3s;
        }

        .filters button.active,
        .filters button:hover{
            background:var(--gold);
            color:#000;
        }

        /* grid */
        .grid{
            max-width:1200px;
            margin:30px auto;
            display:grid;
            grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
            gap:18px;
            padding:0 20px;
        }

        .card{
            background:linear-gradient(145deg,var(--panel),var(--panel2));
            padding:20px;
            border-radius:18px;
            text-align:center;
            border:1px solid rgba(255,255,255,0.05);
            transition:.3s;
            position:relative;
        }

        .card:hover{
            transform:translateY(-8px);
            box-shadow:var(--shadow);
            border-color:var(--gold);
        }

        .card.live{
            border:1px solid var(--green);
            box-shadow:0 0 15px rgba(0,255,153,0.2);
        }

        .avatar{
            width:80px;
            height:80px;
            border-radius:50%;
            object-fit:cover;
            border:2px solid var(--gold);
            margin-bottom:10px;
        }

        .live-badge{
            position:absolute;
            top:10px;
            left:10px;
            background:var(--green);
            color:#000;
            padding:4px 8px;
            font-size:11px;
            border-radius:6px;
            font-weight:bold;
        }

        .btn{
            display:inline-block;
            margin-top:10px;
            padding:8px 14px;
            border-radius:10px;
            background:linear-gradient(45deg,var(--gold),var(--gold2));
            color:#000;
            text-decoration:none;
            font-weight:bold;
            font-size:13px;
        }

        /* modal */
        .modal{
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.8);
            display:none;
            align-items:center;
            justify-content:center;
        }

        .modal-content{
            background:var(--panel);
            padding:25px;
            border-radius:15px;
            width:350px;
            border:1px solid var(--gold);
        }

        input{
            width:100%;
            padding:12px;
            margin:10px 0;
            border-radius:10px;
            border:1px solid var(--border);
            background:#000;
            color:#fff;
        }

        /* podium */
        .podium{
            display:flex;
            justify-content:center;
            gap:15px;
            margin:50px 0;
        }

        .pod{
            background:var(--panel);
            padding:20px;
            border-radius:15px;
            width:200px;
            text-align:center;
            border-top:3px solid var(--gold);
        }

    </style>
</head>
<body>

<div id="tsparticles"></div>

<nav>
    <div class="brand">
        <img src="/logo.png" />
        <h1>JUSTICE CITY</h1>
    </div>

    <div class="nav-links">
        <a class="btn-gold" href="#" onclick="openModal()">أضف قناتك</a>
    </div>
</nav>

<div class="stats">
    <div class="stat">
        <h2><%= stats.totalStreamers %></h2>
        <p>ستريمرز</p>
    </div>
    <div class="stat">
        <h2><%= stats.totalViewers %></h2>
        <p>مشاهدات</p>
    </div>
    <div class="stat">
        <h2 style="color:var(--green)"><%= stats.liveNow %></h2>
        <p>مباشر الآن</p>
    </div>
</div>

<div class="filters">
    <button onclick="filter('all')" class="active">الكل</button>
    <button onclick="filter('live')">مباشر</button>
    <button onclick="filter('offline')">أوفلاين</button>
</div>

<div class="grid">
    <% streamers.forEach(s => { %>
        <div class="card <%= s.isLive ? 'live' : '' %>">
            <% if(s.isLive){ %>
                <div class="live-badge">LIVE</div>
            <% } %>

            <img class="avatar" src="<%= s.profilePic || '/logo.png' %>" />
            <h3><%= s.kickUsername %></h3>
            <p style="color:#888"><%= s.isLive ? s.viewers + ' مشاهدة' : 'غير مباشر' %></p>
            <a class="btn" href="https://kick.com/<%= s.kickUsername %>">دخول</a>
        </div>
    <% }) %>
</div>

<!-- modal -->
<div class="modal" id="modal">
    <div class="modal-content">
        <h3>إضافة قناة</h3>
        <form action="/apply" method="POST">
            <input name="kickUser" placeholder="اسم القناة" />
            <button class="btn" type="submit">إرسال</button>
        </form>
    </div>
</div>

<script>
function openModal(){
    document.getElementById('modal').style.display='flex';
}
function filter(type){
    document.querySelectorAll('.card').forEach(c=>{
        if(type==='all') c.style.display='block';
        if(type==='live') c.style.display=c.classList.contains('live')?'block':'none';
        if(type==='offline') c.style.display=!c.classList.contains('live')?'block':'none';
    });
}

</script>

</body>
</html>
