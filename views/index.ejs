    top: 0;
    z-index: 1000;

    border-bottom: 1px solid rgba(212, 175, 55, 0.25);

    box-shadow: 0 0 25px rgba(0,0,0,0.6);
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;

    padding: 12px 35px;

    background: rgba(10,10,10,0.75);
    backdrop-filter: blur(18px);

    position: sticky;
    top: 0;
    z-index: 1000;

    border-bottom: 1px solid rgba(212,175,55,0.25);
}

/* حاوية الأزرار */
.nav-links {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* شكل الزر الحقيقي (فخم مش boxes) */
.nav-links a {
    position: relative;

    display: flex;
    align-items: center;
    gap: 6px;

    padding: 9px 14px;

    font-size: 13px;
    font-weight: 600;

    color: #d4af37;
    text-decoration: none;

    border-radius: 10px;

    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(212,175,55,0.2);

    transition: 0.25s;
    white-space: nowrap;
}

/* hover احترافي */
.nav-links a:hover {
    background: #d4af37;
    color: #000;
    transform: translateY(-2px);
    box-shadow: 0 0 18px rgba(212,175,55,0.5);
}

/* لمعة ذهبية خفيفة */
.nav-links a::before {
    content: "";
    position: absolute;
    top: 0;
    left: -120%;
    width: 100%;
    height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: 0.5s;
}

.nav-links a:hover::before {
    left: 120%;
}

/* ================= MEDAL & RANKINGS ================= */
.medal {
    font-size: 50px;
    margin-bottom: 10px;
    display: block;
}

/* ================= GRID SYSTEM ================= */
.grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); /* جعل العرض أكبر ليناسب الشكل الأفقي */
    gap: 25px; 
    padding: 20px;
    margin-top: 30px;
}

/* ================= NEW CLEAN HORIZONTAL CARD ================= */
/* ================= THE ROYAL ANIMATED CARD ================= */
.card {
    position: relative;
    background: #0a0a0a;
    border-radius: 20px;
    padding: 25px;
    display: flex;
    flex-direction: row-reverse; 
    align-items: center;
    justify-content: space-between;
    min-height: 160px;
    transition: 0.3s;
    box-sizing: border-box;
    overflow: hidden; /* ضروري عشان حركة الألوان */
    z-index: 1;
}

/* حركة الألوان الذهبية المتحركة في الخلفية */
.card::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(#d4af37, #f9f295, #8a6d3b, #d4af37, #000, #d4af37);
    animation: rotateGlow 6s linear infinite;
    z-index: -2;
}

/* الطبقة اللي بتغطي الألوان وبتحافظ على الإطار الذهبي */
.card::after {
    content: "";
    position: absolute;
    inset: 3px; /* سمك الإطار */
    background: #0a0a0a;
    border-radius: 18px;
    z-index: -1;
}

@keyframes rotateGlow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
}

/* حاوية المعلومات (جهة اليمين) */
.card-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end; 
    gap: 6px;
    margin-right: 20px;
}

.card-info h3 {
    font-size: 24px;
    color: #fff;
    margin: 0;
    text-shadow: 0 0 10px rgba(0,0,0,0.5);
}

.platform-tag {
    background: rgba(0, 255, 153, 0.1);
    color: #00ff99;
    border: 1px solid #00ff99;
    padding: 2px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: bold;
}

.live-text {
    color: #00ff99;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: bold;
}

.red-dot {
    width: 10px;
    height: 10px;
    background: #ff4b4b;
    border-radius: 50%;
    box-shadow: 0 0 10px #ff4b4b;
    animation: pulse-red 1.5s infinite;
}

/* حاوية الصورة والعداد (جهة اليسار) */
.avatar-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px; /* المسافة المطلوبة بين الصورة والعداد */
    min-width: 110px;
}

.avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid #d4af37;
    object-fit: cover;
    background: #000;
}

.viewer-badge {
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
