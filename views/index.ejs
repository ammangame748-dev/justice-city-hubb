<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Justice City Hub | Ultimate Edition</title>

    <link href="https://fonts.googleapis.com/css2?family=Changa:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>

    <style>
        :root{
            --bg:#05060a;
            --glass:rgba(15,15,20,0.65);
            --glass2:rgba(25,25,35,0.55);
            --gold:#d4af37;
            --gold2:#f9f295;
            --text:#fff;
            --muted:#9aa0aa;
            --green:#00ff99;
            --red:#ff3b3b;
            --shadow:0 0 30px rgba(212,175,55,0.25);
        }

        *{margin:0;padding:0;box-sizing:border-box;font-family:'Changa',sans-serif;}

        body{
            background:var(--bg);
            color:var(--text);
            overflow-x:hidden;
        }

        /* particles */
        #tsparticles{
            position:fixed;
            inset:0;
            z-index:-2;
        }

        /* floating logo watermark animation */
        body::before{
            content:"";
            position:fixed;
            top:50%;
            left:50%;
            width:700px;
            height:700px;
            background:url('/logo.png') no-repeat center;
            background-size:contain;
            opacity:0.05;
            transform:translate(-50%,-50%);
            filter:blur(0.5px) drop-shadow(0 0 40px rgba(212,175,55,0.25));
            animation:floatLogo 10s ease-in-out infinite;
            z-index:-1;
            pointer-events:none;
        }

        @keyframes floatLogo{
            0%{transform:translate(-50%,-50%) scale(1) rotate(0deg);}
            50%{transform:translate(-50%,-52%) scale(1.05) rotate(3deg);}
            100%{transform:translate(-50%,-50%) scale(1) rotate(0deg);}
        }

        /* NAV */
        nav{
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:15px 35px;
            background:rgba(10,10,15,0.7);
            backdrop-filter:blur(14px);
            border-bottom:1px solid rgba(212,175,55,0.2);
            position:sticky;
            top:0;
            z-index:1000;
        }

        .brand{
            display:flex;
            align-items:center;
            gap:12px;
        }

        .brand img{
            width:45px;
            height:45px;
            border-radius:12px;
            box-shadow:var(--shadow);
        }

        .brand h1{
            font-size:18px;
            background:linear-gradient(45deg,var(--gold),var(--gold2));
            -webkit-background-clip:text;
            -webkit-text-fill-color:transparent;
            letter-spacing:1px;
        }

        .nav-links a{
            margin-right:10px;
            text-decoration:none;
            color:#fff;
            padding:8px 14px;
            border-radius:10px;
            transition:.3s;
        }

        .nav-links a:hover{
            background:rgba(212,175,55,0.15);
        }

        .btn-gold{
            border:1px solid var(--gold);
            color:var(--gold)!important;
        }

        /* stats */
        .stats{
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:18px;
            max-width:1100px;
            margin:40px auto;
            padding:0 20px;
        }

        .stat{
            background:linear-gradient(145deg,var(--glass),var(--glass2));
            padding:25px;
            border-radius:18px;
            border:1px solid rgba(255,255,255,0.06);
            text-align:center;
            transition:.3s;
        }

        .stat:hover{
            transform:translateY(-6px);
            box-shadow:var(--shadow);
        }

        .stat h2{font-size:30px;color:var(--gold2);}
        .stat p{color:var(--muted);}

        /* filters */
        .filters{
            display:flex;
            justify-content:center;
            gap:10px;
            margin:25px 0;
        }

        .filters button{
            padding:10px 16px;
            border-radius:12px;
            border:1px solid rgba(255,255,255,0.1);
            background:rgba(20,20,25,0.7);
            color:#fff;
            cursor:pointer;
            transition:.3s;
        }

        .filters button.active,
        .filters button:hover{
            background:var(--gold);
            color:#000;
        }

        /* grid */
        .grid{
            display:grid;
            grid-template-columns:repeat(auto-fill,minmax(230px,1fr));
            gap:18px;
            max-width:1200px;
            margin:30px auto;
            padding:0 20px;
        }

        .card{
            background:linear-gradient(145deg,var(--glass),var(--glass2));
            border-radius:20px;
            padding:20px;
            text-align:center;
            border:1px solid rgba(255,255,255,0.05);
            transition:.4s;
            position:relative;
            overflow:hidden;
        }

        .card:hover{
            transform:translateY(-10px) scale(1.02);
            box-shadow:0 0 40px rgba(212,175,55,0.25);
            border-color:var(--gold);
        }

        .card.live{
            border:1px solid var(--green);
            box-shadow:0 0 25px rgba(0,255,153,0.15);
        }

        .avatar{
            width:85px;
            height:85px;
            border-radius:50%;
            object-fit:cover;
            border:2px solid var(--gold);
            margin-bottom:10px;
        }

        .live-badge{
            position:absolute;
            top:10px;
            left:10px;
            background:var(--green);
            color:#000;
            padding:5px 8px;
            border-radius:8px;
            font-size:11px;
            font-weight:bold;
        }

        .top-badge{
            position:absolute;
            top:10px;
            right:10px;
            background:linear-gradient(45deg,var(--gold),var(--gold2));
            color:#000;
            padding:5px 8px;
            border-radius:8px;
            font-size:11px;
            font-weight:bold;
        }

        .btn{
            display:inline-block;
            margin-top:10px;
            padding:8px 14px;
            border-radius:12px;
            background:linear-gradient(45deg,var(--gold),var(--gold2));
            color:#000;
            font-weight:bold;
            text-decoration:none;
        }

        /* modal */
        .modal{
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.85);
            display:none;
            justify-content:center;
            align-items:center;
        }

        .modal-content{
            width:350px;
            background:var(--glass);
            padding:25px;
            border-radius:15px;
            border:1px solid var(--gold);
        }

        input{
            width:100%;
            padding:12px;
            margin:10px 0;
            border-radius:10px;
            border:1px solid rgba(255,255,255,0.1);
            background:#000;
            color:#fff;
        }
    </style>
</head>
<body>

<div id="tsparticles"></div>

<nav>
    <div class="brand">
        <img src="/logo.png" />
        <h1>JUSTICE CITY HUB</h1>
    </div>

    <div class="nav-links">
        <a class="btn-gold" onclick="openModal()">أضف قناتك</a>
    </div>
</nav>

<div class="stats">
    <div class="stat"><h2><%= stats.totalStreamers %></h2><p>ستريمرز</p></div>
    <div class="stat"><h2><%= stats.totalViewers %></h2><p>مشاهدات</p></div>
    <div class="stat"><h2 style="color:var(--green)"><%= stats.liveNow %></h2><p>مباشر</p></div>
</div>

<div class="filters">
    <button class="active" onclick="filter('all')">الكل</button>
    <button onclick="filter('live')">مباشر</button>
    <button onclick="filter('offline')">أوفلاين</button>
</div>

<div class="grid">
<% streamers.forEach(s => { %>

    <% let isTop = s.createdAt && (Date.now() - new Date(s.createdAt)) < 5*24*60*60*1000; %>

    <div class="card <%= s.isLive ? 'live' : '' %>">
        <% if(s.isLive){ %><div class="live-badge">LIVE</div><% } %>
        <% if(isTop){ %><div class="top-badge">TOP</div><% } %>

        <img class="avatar" src="<%= s.profilePic || '/logo.png' %>" />
        <h3><%= s.kickUsername %></h3>

        <p style="color:#aaa"><%= s.isLive ? s.viewers+' مشاهدة' : 'غير مباشر' %></p>

        <a class="btn" href="https://kick.com/<%= s.kickUsername %>" target="_blank">دخول</a>
    </div>

<% }) %>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <h3>إضافة قناة</h3>
        <form action="/apply" method="POST">
            <input name="kickUser" placeholder="اسم القناة" />
            <button class="btn">إرسال</button>
        </form>
    </div>
</div>

<script>
function openModal(){document.getElementById('modal').style.display='flex';}
function filter(t){
document.querySelectorAll('.card').forEach(c=>{
if(t==='all')c.style.display='block';
if(t==='live')c.style.display=c.classList.contains('live')?'block':'none';
if(t==='offline')c.style.display=!c.classList.contains('live')?'block':'none';
});
}

async function loadParticles(){
tsParticles.load("tsparticles",{
particles:{number:{value:60},color:{value:["#d4af37","#ffffff"]},move:{enable:true,speed:1}},background:{color:"#05060a"}
});
}
loadParticles();
</script>

</body>
</html>
