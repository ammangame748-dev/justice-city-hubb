<div class="stats-grid">
    <div class="stat-box">
        <span class="stat-number"><%= stats.totalOrders %></span>
        <span class="stat-desc">إجمالي الطلبات المنفذة</span>
    </div>
    <div class="stat-box">
        <span class="stat-number" style="color: #00ff99;"><%= stats.activeNow %></span>
        <span class="stat-desc">طلبات قيد التثبيت الآن</span>
    </div>
    <div class="stat-box">
        <span class="stat-number">100%</span>
        <span class="stat-desc">ضمان ثبات (30 يوم)</span>
    </div>
</div>
<div class="grid">
    <% if (services && services.length > 0) { %>
        <% services.forEach(function(s) { %>
            <div class="card live"> <!-- نستخدم كلاس live للحفاظ على التوهج -->
                
                <span class="fav-star" data-user="<%= s.targetName %>" onclick="toggleFavorite('<%= s.targetName %>')">☆</span>

                <div class="card-info">
                    <div class="platform-tag" style="background: #d4af37; color: #000;">
                        <%= s.platform.toUpperCase() %>
                    </div>
                    <h3><%= s.targetName %></h3>
                    
                    <div class="live-text">
                        جاري التثبيت <span class="red-dot" style="background: #00ff99; box-shadow: 0 0 10px #00ff99;"></span>
                    </div>

                    <div style="color: #888; font-size: 11px; margin-top: 5px;">
                        تاريخ الانتهاء: <%= new Date(s.expiryDate).toLocaleDateString('ar-EG') %>
                    </div>
                </div>

                <div class="avatar-container">
                    <!-- أيقونة تلقائية بناءً على المنصة -->
                    <img src="/logos/<%= s.platform %>.png" class="avatar" onerror="this.src='/logo.png'">
                    <div class="viewer-badge">
                        <%= s.fakeCount %> <span style="font-size: 10px; margin-right: 4px; opacity: 0.8;">MEMBER</span>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div style="text-align:center; color:#777; grid-column: 1/-1; padding: 50px;">🚫 لا يوجد طلبات نشطة حالياً</div>
    <% } %>
</div>
<div id="apply-modal" style="display: none;">
    <div class="card" style="width: 380px; border: 2px solid #d4af37; padding: 30px; position: relative; flex-direction: column;">
        <h2 style="color: #d4af37; margin-bottom: 20px;">🚀 اطلب تزويد وهمي</h2>
        <form action="/apply" method="POST">
            <input type="text" name="targetName" placeholder="رابط الحساب أو السيرفر" required 
                   style="display: block; width: 100%; box-sizing: border-box; padding: 12px; margin-bottom: 10px; background: #000; color: #fff; border: 1px solid #d4af37; border-radius: 8px;">
            
            <select name="platform" style="display: block; width: 100%; padding: 12px; margin-bottom: 10px; background: #000; color: #fff; border: 1px solid #d4af37; border-radius: 8px;">
                <option value="discord">Discord</option>
                <option value="tiktok">TikTok</option>
                <option value="instagram">Instagram</option>
            </select>

            <button type="submit" class="btn-visit" style="width: 100%; border: none; cursor: pointer;">إرسال الطلب للمراجعة</button>
        </form>
        <button onclick="closeModal()" style="background:none; border:none; color:#555; margin-top:10px; cursor:pointer;">إغلاق</button>
    </div>
</div>
