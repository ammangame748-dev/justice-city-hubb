    padding: 10px 25px;
    border-radius: 12px;
    font-weight: bold;
    text-decoration: none;
    margin-top: 10px;
    transition: 0.3s;
}

@keyframes pulse-red {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 75, 75, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(255, 75, 75, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 75, 75, 0); }
}

/* النجمة في أقصى الزاوية */
.fav-star {
    position: absolute !important; /* كلمة important بتجبرها تطبق الأمر */
    top: 8px !important;
    left: 8px !important;
    right: auto !important; /* عشان نلغي أي تأثير لليمين */
    font-size: 22px;
    color: rgba(255, 255, 255, 0.3); /* لون خفيف عشان ما تخرب الشكل */
    cursor: pointer;
    z-index: 100; /* أعلى من كل الطبقات المتحركة */
    transition: 0.3s;
}



.fav-star.active { 
    color: #d4af37; 
    text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
}


/* ================= FILTERS & FAVS ================= */
.filter-container {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin: 30px 0;
}

.filter-btn {
    background: rgba(20, 20, 20, 0.8);
    color: #d4af37;
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 10px 30px;
    border-radius: 12px;
    cursor: pointer;
    font-family: 'Changa';
    font-weight: bold;
    transition: 0.3s;
}

.filter-btn.active, .filter-btn:hover {
    background: var(--gold);
