    <script>
function filterStreamers(type, event) {
    // 1. تحديث شكل الأزرار (إزالة active من الكل وإضافتها للزر المضغطوط)
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    if (event) {
        event.currentTarget.classList.add('active');
    }

    // 2. جلب كل الكروت الموجودة داخل الـ grid
    const cards = document.querySelectorAll('.grid .card');
    
    cards.forEach(card => {
        // فحص هل الكرت يحتوي على كلاس live (اللي أنت ضايفه أصلاً في EJS)
        const isLive = card.classList.contains('live');

        if (type === 'all') {
            card.style.display = 'block'; // إظهار الكل
        } else if (type === 'live') {
            card.style.display = isLive ? 'block' : 'none'; // إظهار اللايف فقط
        } else if (type === 'offline') {
            card.style.display = !isLive ? 'block' : 'none'; // إظهار الأوفلاين فقط
        }
    });

    console.log("Filtering done for:", type); // للتأكد في Console المتصفح
}


        // وظائف النافذة المنبثقة (Modal)
        function openModal() { 
            document.getElementById('apply-modal').style.display = 'flex'; 
        }
        
        function closeModal() { 
            document.getElementById('apply-modal').style.display = 'none'; 
        }

        // وظيفة إظهار وإخفاء المتصدرين (Rankings)
        function toggleRankings() {
            const rankings = document.getElementById('rankings');
            // التأكد من حالة العرض الحالية
            if (rankings.style.display === 'none' || rankings.style.display === '') {
                rankings.style.display = 'block';
                // نزول تلقائي للقسم عند فتحه
                rankings.scrollIntoView({ behavior: 'smooth' });
            } else {
                rankings.style.display = 'none';
            }
        }

        // إغلاق النافذة عند الضغط خارجها (اختياري لزيادة الاحترافية)
        window.onclick = function(event) {
            const modal = document.getElementById('apply-modal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
