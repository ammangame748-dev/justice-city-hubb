<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة التحكم | Justice City</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        body { background: #050505; color: white; font-family: 'Changa', sans-serif; padding: 40px; }
        h2 { color: #d4af37; border-bottom: 2px solid #d4af37; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 40px; background: rgba(20,20,20,0.8); }
        th, td { padding: 15px; border: 1px solid rgba(212,175,55,0.2); text-align: center; }
        th { background: #d4af37; color: black; }
        .btn { padding: 8px 15px; text-decoration: none; border-radius: 5px; font-weight: bold; color: white; cursor: pointer; }
        .btn-accept { background: #28a745; margin-left: 5px; }
        .btn-reject { background: #dc3545; }
        .btn-delete { background: #ff4d4d; border: none; }
        .back-link { display: inline-block; margin-bottom: 20px; color: #d4af37; text-decoration: none; }
    </style>
</head>
<body>

    <a href="/" class="back-link">🔙 العودة للموقع الرئيسي</a>

    <h2>👑 طلبات الانضمام المعلقة (<%= apps.length %>)</h2>
    <table>
        <thead>
            <tr>
                <th>اسم الستريمر (Kick)</th>
                <th>ديسكورد</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            <% if (apps.length === 0) { %>
                <tr><td colspan="3">لا توجد طلبات جديدة حالياً</td></tr>
            <% } %>
            <% apps.forEach(app => { %>
                <tr>
                    <td><%= app.kickUsername %></td>
                    <td><%= app.discordName %></td>
                    <td>
                        <a href="/admin/accept/<%= app._id %>?pass=1234" class="btn btn-accept">قبول ✅</a>
                        <a href="/admin/reject/<%= app._id %>?pass=1234" class="btn btn-reject">رفض ❌</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <h2>🚫 الستريمرز الحاليين في الموقع (<%= streamers.length %>)</h2>
    <table>
        <thead>
            <tr>
                <th>الصورة</th>
                <th>الاسم</th>
                <th>الحالة</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            <% streamers.forEach(s => { %>
                <tr>
                    <td><img src="<%= s.profilePic %>" width="40" style="border-radius: 50%;"></td>
                    <td><%= s.kickUsername %></td>
                    <td><%= s.isLive ? '🔴 لايف' : '⚪ أوفلاين' %></td>
                    <td>
                        <a href="/admin/delete-streamer/<%= s._id %>?pass=1234" class="btn btn-reject" onclick="return confirm('متأكد بدك تحذفه؟')">حذف من الموقع 🗑️</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>
