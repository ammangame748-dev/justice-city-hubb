<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم | Justice City</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        body {
            margin: 0;
            font-family: 'Changa', sans-serif;
            background-color: #0a0a0a;
            background-image: url('/pattern.png');
            background-repeat: repeat;
            background-attachment: fixed;
            background-size: 300px;
            color: white;
            padding: 40px 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        h1,
        h2 {
            color: #d4af37;
            text-align: center;
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
            margin-bottom: 30px;
        }

        h2 {
            text-align: right;
            border-bottom: 2px solid rgba(212, 175, 55, 0.2);
            padding-bottom: 10px;
            margin-top: 50px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .adm-card {
            background: rgba(15, 15, 15, 0.85);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 15px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            backdrop-filter: blur(5px);
            transition: 0.3s;
        }

        .adm-card:hover {
            border-color: #d4af37;
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.1);
        }

        .info-group {
            margin-bottom: 15px;
        }

        .info-label {
            color: #888;
            font-size: 13px;
            display: block;
        }

        .info-value {
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .btn {
            flex: 1;
            padding: 10px;
            border-radius: 8px;
            font-family: 'Changa', sans-serif;
            font-weight: bold;
            font-size: 14px;
            text-decoration: none;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-accept {
            background-color: #00ff99;
            color: #000;
            border: none;
        }

        .btn-accept:hover {
            background-color: #00cc7a;
            box-shadow: 0 0 10px rgba(0, 255, 153, 0.4);
        }

        .btn-reject {
            background-color: rgba(255, 51, 51, 0.1);
            color: #ff3333;
            border: 1px solid #ff3333;
        }

        .btn-reject:hover {
            background-color: #ff3333;
            color: #fff;
            box-shadow: 0 0 10px rgba(255, 51, 51, 0.4);
        }

        .empty-msg {
            color: #666;
            text-align: center;
            grid-column: 1 / -1;
            padding: 40px;
            font-size: 18px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
            border: 1px dashed rgba(255, 255, 255, 0.05);
        }
    </style>
</head>

<body>

    <div class="container">
        <h1>👑 لوحة تحكم مجتمع Justice City</h1>

        <!-- قسم طلبات الانضمام المعلقة -->
        <h2>📥 طلبات الانضمام الجديدة المنتظرة</h2>
        <div class="grid">
            <% if (apps.length===0) { %>
                <div class="empty-msg">لا توجد طلبات انضمام جديدة حالياً.</div>
                <% } else { %>
                    <% apps.forEach(app=> { %>
                        <div class="adm-card">
                            <div class="info-group">
                                <span class="info-label">حساب Kick:</span>
                                <span class="info-value">
                                    <%= app.kickUsername %>
                                </span>
                            </div>
                            <div class="info-group">
                                <span class="info-label">حساب Discord:</span>
                                <span class="info-value">
                                    <%= app.discordName || 'غير متوفر' %>
                                </span>
                            </div>
                            <div class="btn-group">
                                <a href="/admin/accept/<%= app._id %>?pass=1234" class="btn btn-accept">قبول التقديم</a>
                                <a href="/admin/reject/<%= app._id %>?pass=1234" class="btn btn-reject">رفض وحذف</a>
                            </div>
                        </div>
                        <% }) %>
                            <% } %>
        </div>

        <!-- قسم الستريمرز الحاليين بالموقع -->
        <h2>👥 الستريمرز المسجلين بالموقع حالياً</h2>
        <div class="grid">
            <% if (streamers.length===0) { %>
                <div class="empty-msg">لا يوجد ستريمرز مضافين في الموقع حتى الآن.</div>
                <% } else { %>
                    <% streamers.forEach(streamer=> { %>
                        <div class="adm-card" style="border-color: rgba(255,255,255,0.05);">
                            <div class="info-group">
                                <span class="info-label">اسم الستريمر (Kick):</span>
                                <span class="info-value" style="color: #d4af37;">
                                    <%= streamer.kickUsername %>
                                </span>
                            </div>
                            <div class="info-group">
                                <span class="info-label">حالة البث الحالية:</span>
                                <span class="info-value">
                                    <%= streamer.isLive ? '🟢 بث مباشر' : '🔴 أوفلاين' %>
                                </span>
                            </div>
                            <div class="btn-group">
                                <a href="/admin/delete-streamer/<%= streamer._id %>?pass=1234" class="btn btn-reject"
                                    style="width: 100%;">طرد وإزالة من الموقع</a>
                            </div>
                        </div>
                        <% }) %>
                            <% } %>
        </div>
    </div>

</body>

</html>