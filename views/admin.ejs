<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة التحكم | Justice City</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        body { font-family: 'Changa', sans-serif; background: #0a0a0a; color: white; text-align: center; }
        .admin-card { background: #151515; border: 1px solid #d4af37; border-radius: 15px; width: 90%; max-width: 500px; margin: 50px auto; padding: 30px; box-shadow: 0 0 20px rgba(212, 175, 55, 0.2); }
        h2 { color: #d4af37; }
        input, select { width: 100%; padding: 12px; margin: 10px 0; background: #000; border: 1px solid #333; color: white; border-radius: 8px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: linear-gradient(45deg, #d4af37, #f9f295); border: none; border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .service-list { margin-top: 30px; text-align: right; }
        .service-item { background: #222; padding: 10px; border-radius: 8px; margin-bottom: 5px; display: flex; justify-content: space-between; border-right: 4px solid #d4af37; }
    </style>
</head>
<body>

    <div class="admin-card">
        <h2>🚀 إضافة خدمة وهمية</h2>
        <form action="/admin/add-fake" method="POST">
            <input type="hidden" name="pass" value="1234"> <!-- عدل الرقم السري هون -->
            <input type="text" name="targetName" placeholder="اسم السيرفر أو الحساب" required>
            <input type="number" name="count" placeholder="عدد المتابعين الوهمي" required>
            <select name="platform">
                <option value="discord">Discord</option>
                <option value="tiktok">TikTok</option>
                <option value="instagram">Instagram</option>
                <option value="twitter">Twitter</option>
            </select>
            <input type="number" name="months" placeholder="المدة بالشهور (مثلاً 1)" value="1">
            <button type="submit">تفعيل التزويد الآن</button>
        </form>

        <div class="service-list">
            <h3>الخدمات النشطة حالياً:</h3>
            <% services.forEach(function(s) { %>
                <div class="service-item">
                    <span><%= s.targetName %> (<%= s.platform %>)</span>
                    <a href="/admin/delete-service/<%= s._id %>?pass=1234" style="color: #ff4b4b; text-decoration: none;">حذف ❌</a>
                </div>
            <% }); %>
        </div>
    </div>

</body>
</html>
